# =========================
# Operating System & IDEs
# =========================
.DS_Store
.AppleDouble
.LSOverride
.idea/
.vscode/
*.swp
*.swo
*~

# =========================
# Gradle & Java (Backend)
# =========================
.gradle/
**/build/
out/
bin/
*.class
*.log
*.jar
*.war
# Keep the wrapper
!gradle-wrapper.jar

# =========================
# Node.js & React (Frontend)
# =========================
**/node_modules/
**/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# =========================
# Terraform (Infrastructure)
# =========================
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfvars
infra/crash.log
# Keep the lock file to ensure deterministic provider versions
!infra/.terraform.lock.hcl

# =========================
# Secrets & Credentials (CRITICAL)
# =========================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
*-sa-key.json
gcp-service-account.json

